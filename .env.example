ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/fitness_life
DATABASE_SSL=false
# Supabase example:
# DATABASE_URL=postgresql+psycopg2://postgres:YOUR_PASSWORD@db.xxxxx.supabase.co:5432/postgres
# DATABASE_SSL=true

# JWT Secret: Gere com `python -c "import secrets; print(secrets.token_urlsafe(32))"`
# Minimo 32 caracteres em producao
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# Tempo de expiracao do token (em minutos)
# Recomendado: 15-60 em producao, 1440 (24h) so em desenvolvimento
ACCESS_TOKEN_EXPIRE_MINUTES=1440
RATE_LIMIT_REGISTER=3/minute
RATE_LIMIT_LOGIN=5/minute

# API URLs
API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
FRONTEND_ORIGINS=http://localhost:3000

# Groq API (opcional - para funcionalidades de IA)
GROQ_API_KEY=
